exports[`Upload summary tests > Upload summary pages for an imported users that already exist matches Snapshot 1`] = `
{
  "asFragment": [Function],
  "baseElement": <body>
    <div>
      <h1
        class="ons-u-mb-l"
      >
        Bulk upload 
        <em>
          one
        </em>
         user
        ?
      </h1>
      <div
        data-testid="summary-panel"
      >
        <div
          class="ons-panel ons-panel--info ons-panel--no-title ons-u-mt-m"
          id="panel-_r_c_"
        >
          <span
            class="ons-panel__assistive-text ons-u-vh"
          >
            Important information:
             
          </span>
          <div
            class="ons-panel__body "
          >
            <p>
              1
               of 
              3
               users are valid and will be uploaded.
               
              <em>
                Invalid users will not be uploaded.
              </em>
               You can review any issues in the table below.
            </p>
          </div>
        </div>
      </div>
      <form
        class="ons-u-mt-s"
      >
        <fieldset
          class="ons-fieldset"
        >
          <legend
            class="ons-fieldset__legend"
          />
          <div
            class="ons-radios__items"
          >
            <p
              class="ons-radios__item"
            >
              <span
                class="ons-radio"
              >
                <input
                  aria-label="Yes"
                  class="ons-radio__input ons-js-radio "
                  id="confirm-upload"
                  name="confirm-upload"
                  type="radio"
                  value="True"
                />
                <label
                  class="ons-radio__label "
                  for="confirm-upload"
                >
                  Yes, upload 
                  one
                   valid user
                </label>
              </span>
            </p>
            <br />
            <p
              class="ons-radios__item"
            >
              <span
                class="ons-radio"
              >
                <input
                  aria-label="No"
                  class="ons-radio__input ons-js-radio "
                  id="cancel-upload"
                  name="confirm-upload"
                  type="radio"
                  value="False"
                />
                <label
                  class="ons-radio__label "
                  for="cancel-upload"
                >
                  No, do not upload any users
                </label>
              </span>
            </p>
          </div>
        </fieldset>
        <br />
        <button
          class="ons-btn"
          data-testid="confirm-continue-button"
          id="confirm-continue"
          type="button"
        >
          <span
            class="ons-btn__inner"
          >
            <span
              class="ons-btn__text"
            >
              Continue
            </span>
          </span>
        </button>
        <button
          class="ons-btn ons-btn--secondary"
          data-testid="cancel-overwrite-button"
          id="cancel-overwrite"
          type="button"
        >
          <span
            class="ons-btn__inner"
          >
            <span
              class="ons-btn__text"
            >
              Cancel
            </span>
          </span>
        </button>
      </form>
      <h2
        class="ons-u-mt-xl"
      >
        Users to upload
      </h2>
      <div
        class="ons-table-scrollable ons-table-scrollable--on"
      >
        <div
          aria-label="Users to upload table"
          class="ons-table-scrollable__content"
          role="region"
          tabindex="0"
        >
          <table
            class="ons-table"
            data-testid="batch-table-table"
            id="batch-table"
          >
            <thead
              class="ons-table__head"
            >
              <tr
                class="ons-table__row"
              >
                <th
                  class="ons-table__header ons-table__header--top"
                  scope="col"
                >
                  <span
                    class="ons-table__header-text"
                  >
                    Username
                  </span>
                </th>
                <th
                  class="ons-table__header ons-table__header--top"
                  scope="col"
                >
                  <span
                    class="ons-table__header-text"
                  >
                    Role
                  </span>
                </th>
                <th
                  class="ons-table__header ons-table__header--top"
                  scope="col"
                >
                  <span
                    class="ons-table__header-text"
                  >
                    User validity
                  </span>
                </th>
              </tr>
            </thead>
            <tbody
              class="ons-table__body"
            >
              <tr
                class="ons-table__row"
                data-testid="user-table-row-0"
              >
                <td
                  class="ons-table__cell "
                >
                  Jamie
                </td>
                <td
                  class="ons-table__cell "
                >
                  BDSS
                </td>
                <td
                  class="ons-table__cell "
                >
                  <span
                    class="ons-status ons-status--error"
                  >
                    User already exists. 
                  </span>
                </td>
              </tr>
              <tr
                class="ons-table__row"
                data-testid="user-table-row-1"
              >
                <td
                  class="ons-table__cell "
                >
                  Rich
                </td>
                <td
                  class="ons-table__cell "
                >
                  BDSS
                </td>
                <td
                  class="ons-table__cell "
                >
                  <span
                    class="ons-status ons-status--error"
                  >
                    User already exists. 
                  </span>
                </td>
              </tr>
              <tr
